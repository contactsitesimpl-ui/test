      </div>
      <button id="menuBtn" class="md:hidden p-2 -mr-2 text-foreground" aria-label="Toggle menu">
        <i data-lucide="menu" class="h-6 w-6"></i>
      </button>
    </div>
    <div id="mobileMenu" class="hidden md:hidden border-t bg-background absolute w-full shadow-xl">
      <nav class="container mx-auto flex flex-col gap-2 px-6 py-6">
        <a href="index.html" class="text-lg font-semibold py-3 border-b border-border/50">Home</a>
        <a href="pricing.html" class="text-lg font-semibold py-3 border-b border-border/50">Pricing</a>
        <a href="examples.html" class="text-lg font-semibold py-3 border-b border-border/50">Examples</a>
        <a href="faqs.html" class="text-lg font-semibold py-3 border-b border-border/50 text-primary">FAQs</a>
        <a href="quote.html" class="text-lg font-semibold py-3 border-b border-border/50">Get Quote</a>
        <div class="pt-6 flex flex-col gap-3">
